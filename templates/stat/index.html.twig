{% extends 'base.html.twig' %}

{% block title %}Statistiques
{% endblock %}

{% block body %}
	<h2>📊 Statistiques
	</h2>
	<table class="table">
		<tr>
			<th>ID</th>
			<th>Nom</th>
			<th>Catégorie</th>
			<th>Durée</th>
		</tr>
		{% for tache in taches %}
			<tr>
				<td>
					{{tache.id}}
				</td>
				<td>{{tache.nom}}</td>
				<td>{{tache.categorie}}</td>
				{# <td>{{ dump(tache.duration)  }}</td> #}
				{# <td>{{tache.duration |format_datetime('full', 'full', locale: 'fr')}}</td> #}
				{# <td>{{ {{ (tache.dateFin).diff(tache.dateDebut)|date("%i'%s''") }} }}</td> #}
					<td>
					{% if tache.duration.days >= 1 %}
						{{tache.duration.days }}
					jours
					{% endif %}
				{{tache.duration |date(" %hh %imin")  }}
			</td>

				{# Différence entre deux dates en twig #}
				{# <td>
				{% set difference = date(tache.dateDebut).diff(tache.dateFin) %}
				{{ difference.format('%H:%I:%S') }}
				</td> #}
			</tr>
		{% endfor %}
	</table>
{% endblock %}
